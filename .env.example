# Copy to .env.local and fill in real values. Validated by packages/db/src/env.ts (zod).
ELEVENLABS_API_KEY=sk_your_elevenlabs_api_key
ELEVENLABS_WEBHOOK_SECRET=wsec_your_webhook_secret
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Stripe billing (Phase 5)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Phase 6 — all optional (features degrade gracefully without them)
# Transactional email (welcome, cap warnings, dunning, weekly summary).
# Magic-link emails go through Supabase Auth: set Resend as the project's SMTP
# (dashboard → Auth → SMTP: host smtp.resend.com, user "resend", pass = API key)
# and customize the magic-link template there.
RESEND_API_KEY=re_...
EMAIL_FROM="Airtalk <hello@yourdomain.com>"
# Absolute origin used inside email links.
APP_URL=https://app.yourdomain.com
# Inngest (async jobs: classification, reconcile, status poll, emails).
# Prod: install the Inngest Vercel integration (sets these). Local: `npx inngest-cli dev` + INNGEST_DEV=1.
INNGEST_EVENT_KEY=...
INNGEST_SIGNING_KEY=signkey-...
# Upstash rate limiting (auth + webhook routes). Absent = no limiting.
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=...
# Sentry: server (SENTRY_DSN above the fold if unset) and browser.
SENTRY_DSN=https://...@o0.ingest.sentry.io/0
NEXT_PUBLIC_SENTRY_DSN=https://...@o0.ingest.sentry.io/0
# Manual-trigger secret for /api/cron/reconcile (route refuses without it).
CRON_SECRET=generate-a-long-random-string
